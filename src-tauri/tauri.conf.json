{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "Screen Tracker",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "window": { "all": true }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.screentracker.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": null
    },
    "systemTray": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    },
    "windows": [
      {
        "label": "main",
        "title": "Screen Tracker",
        "width": 340,
        "height": 480,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": false
      },
      {
        "label": "setup",
        "title": "Screen Tracker — Setup",
        "url": "setup.html",
        "width": 520,
        "height": 620,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "password",
        "title": "Screen Tracker — Admin",
        "url": "password.html",
        "width": 320,
        "height": 180,
        "resizable": false,
        "fullscreen": false,
        "decorations": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "center": true
      }
    ]
  }
}
